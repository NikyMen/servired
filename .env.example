# Copiá lo que necesites a .env.local y completá los valores.
#
# .env      -> valores por defecto, SIN secretos (está trackeado por git)
# .env.local -> tus secretos (lo ignora .gitignore, nunca se commitea)

# MongoDB para preinscripciones. Ejemplo Atlas:
# mongodb+srv://usuario:clave@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=""
MONGODB_DB="servired"

# Si MONGODB_URI está vacío, el desarrollo local conserva el fallback SQLite.
DATABASE_URL="file:./dev.db"

# Acceso a /admin (no los publiques ni los subas al repositorio)
ADMIN_EMAIL="admin@servired.ar"
ADMIN_PASSWORD="cambiá-esta-clave"
ADMIN_SESSION_SECRET="cambiá-este-secreto-largo"

# ServiRed IA. Sacala en https://platform.deepseek.com/api_keys
# VA EN .env.local, no acá ni en .env: los dos van a git.
DEEPSEEK_API_KEY=""
