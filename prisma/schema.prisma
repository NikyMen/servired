// SERVIRED — esquema de base de datos
// Marketplace de servicios: clientes <-> profesionales verificados

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Cuenta de usuario. `role` define con qué cara entra a la app:
/// cliente (azul, contrata) o profesional (verde, ofrece).
model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String // scrypt: "salt:hash" (ver src/lib/auth.ts)
  name         String
  role         String @default("cliente") // cliente | profesional
  avatarColor  String @default("#2563eb")

  /// Perfil público. Solo lo tienen las cuentas con role = profesional.
  professional Professional?

  sessions      Session[]
  conversations Conversation[]
  bookings      Booking[]
  requests      ServiceRequest[]

  createdAt DateTime @default(now())
}

/// Sesión activa. El token vive en una cookie httpOnly; al salir se borra la fila.
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/// Preinscripción: alguien deja sus datos para entrar cuando abramos.
/// No la borra el seed: son contactos reales, no datos de demo.
model Preregistration {
  id    String @id @default(cuid())
  name  String
  email String @unique // evita duplicados si alguien manda el form dos veces
  phone String
  type  String @default("cliente") // cliente | profesional

  createdAt DateTime @default(now())
}

/// Categorías de servicio (Plomería, Electricidad, Limpieza, etc.)
model Category {
  id            String           @id @default(cuid())
  slug          String           @unique
  name          String
  icon          String // nombre de ícono / emoji para la UI
  professionals Professional[]
  requests      ServiceRequest[]

  createdAt DateTime @default(now())
}

/// Solicitud de presupuesto publicada por un cliente
model ServiceRequest {
  id          String   @id @default(cuid())
  title       String
  description String
  zone        String
  budget      Int? // presupuesto estimado opcional (ARS)
  contactName String // nombre mostrado; la identidad real es userId
  status      String   @default("abierta") // abierta | cerrada
  createdAt   DateTime @default(now())

  /// Quién la publicó. Sin esto, un profesional no tendría a quién contestarle.
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
}

/// Profesional / prestador de servicios
model Professional {
  id              String  @id @default(cuid())
  name            String
  headline        String // "Plomero", "Electricista", ...
  bio             String?
  avatarColor     String  @default("#059669") // color para el avatar generado
  rating          Float   @default(0)
  reviewsCount    Int     @default(0)
  zone            String // "Zona Norte, CABA"
  priceFrom       Int // precio "desde" en ARS
  verified        Boolean @default(false)
  featured        Boolean @default(false)
  yearsExperience Int     @default(0)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  /// Cuenta dueña del perfil. Opcional: el seed puede crear perfiles sin cuenta.
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  services      Service[]
  reviews       Review[]
  bookings      Booking[]
  conversations Conversation[]

  createdAt DateTime @default(now())
}

/// Contratación: un cliente contrata a un profesional
model Booking {
  id         String  @id @default(cuid())
  clientName String // nombre mostrado; la identidad real es userId
  note       String?
  status     String  @default("solicitada") // solicitada | aceptada | completada | cancelada

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Conversación entre un cliente y un profesional
model Conversation {
  id         String @id @default(cuid())
  clientName String // nombre mostrado; la identidad real es userId

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Un solo hilo por par cliente-profesional (dos clientes homónimos ya no chocan).
  @@unique([professionalId, userId])
}

/// Mensaje dentro de una conversación
model Message {
  id     String @id @default(cuid())
  sender String // cliente | profesional
  text   String @default("") // puede ir vacío si el mensaje es solo un adjunto

  /// Adjunto opcional (imagen o PDF) servido desde /uploads.
  attachmentUrl  String?
  attachmentName String?
  attachmentType String? // image/jpeg | image/png | image/webp | application/pdf
  attachmentSize Int? // bytes

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/// Servicio publicado por un profesional
model Service {
  id            String @id @default(cuid())
  title         String
  description   String
  categoryLabel String // etiqueta libre: "Electricidad", "Redes", ...
  priceFrom     Int
  status        String @default("activo") // activo | pausado
  requestsCount Int    @default(0)

  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  bookings Booking[]

  createdAt DateTime @default(now())
}

/// Reseña verificada dejada por un cliente
model Review {
  id         String   @id @default(cuid())
  authorName String
  rating     Int
  comment    String
  serviceTag String? // servicio al que refiere la opinión
  createdAt  DateTime @default(now())

  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}
